{
  "name": "loopguard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:backend": "node src/server.js",
    "start": "node src/server.js",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:agent && npm run test:backend",
    "test:agent": "node --import tsx --test tests/agent.test.ts tests/policy.test.ts tests/target.test.ts",
    "test:backend": "node --test test/server.test.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@ant-design/nextjs-registry": "^1.3.0",
    "antd": "^6.5.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "24.0.15",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "eslint": "9.31.0",
    "eslint-config-next": "^16.2.10",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
